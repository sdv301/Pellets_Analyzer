# ============================================================
# Pellets Analyzer — Переменные окружения
# ============================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ============================================================

# --- Секретный ключ Flask (обязательно!) ---
# Сгенерируйте случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-64-char-hex-string

# --- Flask окружение ---
FLASK_ENV=production

# --- База данных ---
DATABASE_URL=sqlite:///pellets_data.db
# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/pellets

# --- SMTP / Email ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Pellets Analyzer <noreply@pellets-analyzer.com>

# --- SSH туннель (если используется удалённая БД) ---
SSH_HOST=your-server.com
SSH_PORT=22
SSH_USER=your_username
SSH_KEY_PATH=/app/keys/id_rsa

# --- Gunicorn (продакшен сервер) ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:5000

# --- Логирование ---
LOG_LEVEL=INFO
LOG_FILE=app_errors.log
